# Copy this to .env and fill in your values
SECRET_KEY=your_random_secret_key_here
ANTHROPIC_API_KEY=sk-ant-...
WC_STORE_URL=https://yourstore.pl
WC_CONSUMER_KEY=ck_...
WC_CONSUMER_SECRET=cs_...
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_app_password
ALLEGRO_CLIENT_ID=your_allegro_client_id
ALLEGRO_CLIENT_SECRET=your_allegro_client_secret
ALLEGRO_SANDBOX=false
ALLEGRO_REDIRECT_URI=https://your-domain.railway.app/api/allegro/auth/callback

# Social Media Agent
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://your-domain.railway.app/api/social/meta/auth/callback
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://your-domain.railway.app/api/social/tiktok/auth/callback
